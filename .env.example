# City Simulator - Environment Configuration
# Copy this file to .env and adjust values for your local setup.
# Usage: source .env   (or: export $(grep -v '^#' .env | xargs))
# CLI flags always take precedence over these variables.

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Select which LLM backend to use. Supported values: ollama (default), openrouter
LLM_PROVIDER=ollama

# ── Ollama (used when LLM_PROVIDER=ollama) ───────────────────────────────────
# Ollama server base URL
OLLAMA_URL=http://localhost:11434

# Ollama model name to use for character dialogue
OLLAMA_MODEL=llama3

# ── OpenRouter (used when LLM_PROVIDER=openrouter) ───────────────────────────
# API key from https://openrouter.ai — required when LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=

# Model identifier passed to OpenRouter (e.g. openai/gpt-4o-mini, anthropic/claude-3-haiku)
# Defaults to openai/gpt-4o-mini if not set
OPENROUTER_MODEL=openai/gpt-4o-mini

# Base URL override for the OpenRouter API (leave empty to use the default)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Simulation ────────────────────────────────────────────────────────────────
# Scenario name under simulations/ or absolute path to a scenario directory
SIM_SCENARIO=default

# Number of simulation ticks (turns) to run
SIM_TURNS=10

# Random seed for character selection (0 = deterministic round-robin)
SIM_SEED=0

# Output file path for the JSONL simulation log
SIM_OUTPUT=simulation_output.jsonl

# Language for narrator and character LLM responses (e.g. Spanish, English, French).
# Leave empty to use the model's default language.
SIM_LANGUAGE=
